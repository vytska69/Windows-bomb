<Window x:Class="WinIsoOptimizer.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinIsoOptimizer.App.ViewModels"
        Title="Windows ISO optimizatorius"
        Height="720" Width="980"
        MinHeight="560" MinWidth="760">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Not disabled while a job is running: the Cancel button lives inside this TabControl's
             content (Kūrimas tab), so disabling the whole control would make it unreachable exactly
             when it's needed. Each action button already gates itself via its command's CanExecute. -->
        <TabControl Grid.Row="0" AutomationProperties.Name="Optimizavimo skirtukai">

            <!-- ============================ ŠALTINIS ============================ -->
            <TabItem Header="_Šaltinis">
                <StackPanel Margin="12">
                    <Label Content="Windows ISO failas:" Target="{Binding ElementName=SourceIsoBox}" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Naršyti..." Width="100" Margin="8,0,0,0"
                                Click="BrowseSourceIso_Click"
                                AutomationProperties.Name="Naršyti Windows ISO failo" />
                        <TextBox x:Name="SourceIsoBox" Text="{Binding SourceIsoPath, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Windows ISO failo kelias" />
                    </DockPanel>

                    <Label Content="Darbinis aplankas (laikini failai):" Target="{Binding ElementName=WorkDirBox}" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Naršyti..." Width="100" Margin="8,0,0,0"
                                Click="BrowseWorkingDirectory_Click"
                                AutomationProperties.Name="Naršyti darbinio aplanko" />
                        <TextBox x:Name="WorkDirBox" Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Darbinio aplanko kelias" />
                    </DockPanel>

                    <Button Content="_Įkelti ISO" Width="160" HorizontalAlignment="Left" Margin="0,4,0,12"
                            Command="{Binding LoadSourceCommand}"
                            AutomationProperties.Name="Įkelti ir išanalizuoti pasirinktą ISO failą"
                            AutomationProperties.HelpText="Išpakuoja ISO turinį ir nuskaito Windows leidimus bei įdiegtas programėles." />

                    <Label Content="Windows leidimas šiame ISO faile:" Target="{Binding ElementName=EditionsList}" />
                    <ListBox x:Name="EditionsList" Height="110" Margin="0,0,0,8"
                             ItemsSource="{Binding Editions}"
                             SelectedItem="{Binding SelectedEdition}"
                             DisplayMemberPath="Name"
                             AutomationProperties.Name="Windows leidimai šiame ISO faile" />

                    <TextBlock Text="Senų sistemų (7 / Vista / XP / 8.1) UEFI paleidimo patikra:" FontWeight="Bold" Margin="0,8,0,2" />
                    <TextBlock Text="{Binding LegacyUefiBootStatus}" TextWrapping="Wrap"
                               AutomationProperties.Name="Senų sistemų UEFI paleidimo patikros rezultatas" />
                </StackPanel>
            </TabItem>

            <!-- ============================ TELEMETRIJA / OPTIMIZAVIMAS ============================ -->
            <TabItem Header="_Telemetrija ir optimizavimas">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <GroupBox Header="Telemetrijos ir privatumo nustatymai" Margin="0,0,0,12"
                                  AutomationProperties.Name="Telemetrijos ir privatumo nustatymų grupė">
                            <StackPanel Margin="8">
                                <CheckBox Content="Taikyti privatumo/telemetrijos registro politikas (AllowTelemetry, reklamos ID, Cortana, pasiūlymai ir kt.)"
                                          IsChecked="{Binding ApplyPrivacyRegistryTweaks}" Margin="0,4" />
                                <CheckBox Content="Išjungti telemetrijos paslaugas (DiagTrack, dmwappushservice)"
                                          IsChecked="{Binding DisableTelemetryServices}" Margin="0,4" />
                                <CheckBox Content="Išjungti telemetrijos suplanuotas užduotis (Compatibility Appraiser, CEIP, Feedback ir kt.)"
                                          IsChecked="{Binding DisableTelemetryScheduledTasks}" Margin="0,4" />
                                <CheckBox Content="Pašalinti OneDrive diegimo failus iš atvaizdo"
                                          IsChecked="{Binding RemoveOneDriveSetup}" Margin="0,4" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Atvaizdo (WIM) valymas" Margin="0,0,0,12"
                                  AutomationProperties.Name="Atvaizdo valymo nustatymų grupė">
                            <StackPanel Margin="8">
                                <CheckBox Content="Išvalyti komponentų saugyklą (StartComponentCleanup, saugu, grįžtama)"
                                          IsChecked="{Binding ComponentStoreCleanup}" Margin="0,4" />
                                <CheckBox IsChecked="{Binding ComponentStoreResetBase}" Margin="0,4">
                                    <TextBlock Text="Taip pat visam laikui pašalinti pakeistų naujinimų senas versijas (ResetBase) — negrįžtama šiam WIM failui, bet sumažina dydį"
                                               TextWrapping="Wrap" />
                                </CheckBox>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Senų sistemų UEFI paleidimas" AutomationProperties.Name="Senų sistemų UEFI paleidimo nustatymų grupė">
                            <StackPanel Margin="8">
                                <CheckBox IsChecked="{Binding ApplyLegacyUefiBootFix}" Margin="0,4">
                                    <TextBlock Text="Pritaikyti UEFI paleidimo pataisą, jei ji tinka šiam ISO (žr. skirtuką „Šaltinis“ dėl paaiškinimo)"
                                               TextWrapping="Wrap" />
                                </CheckBox>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================ PROGRAMĖLĖS ============================ -->
            <TabItem Header="_Programėlės">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8" TextWrapping="Wrap"
                               Text="Pažymėkite programėles, kurias norite pašalinti iš pasirinkto Windows leidimo. Sąrašas užpildomas įkėlus ISO failą ir pasirinkus leidimą." />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableApps}"
                                      AutomationProperties.Name="Programėlių, kurias galima pašalinti, sąrašas">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding AccessibleDescription}"
                                              IsChecked="{Binding IsSelected}"
                                              Margin="0,3"
                                              AutomationProperties.Name="{Binding AccessibleDescription}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ============================ DRAIVERIAI ============================ -->
            <TabItem Header="_Draiveriai">
                <StackPanel Margin="12">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Galite išsitraukti visus trečiųjų šalių draiverius iš šiuo metu veikiančios Windows sistemos ir įdėti juos į ISO, kad nauja sistema iškart atpažintų šio kompiuterio aparatinę įrangą." />

                    <Label Content="Aplankas draiveriams eksportuoti / importuoti:" Target="{Binding ElementName=DriverFolderBox}" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Naršyti..." Width="100" Margin="8,0,0,0"
                                Click="BrowseDriverFolder_Click"
                                AutomationProperties.Name="Naršyti draiverių aplanko" />
                        <TextBox x:Name="DriverFolderBox" Text="{Binding DriverExportFolder, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Draiverių aplanko kelias" />
                    </DockPanel>

                    <Button Content="_Eksportuoti draiverius iš šios sistemos" Width="280" HorizontalAlignment="Left" Margin="0,0,0,12"
                            Command="{Binding ExportDriversCommand}"
                            AutomationProperties.Name="Eksportuoti draiverius iš šiuo metu veikiančios sistemos" />

                    <ListBox Height="140" Margin="0,0,0,12"
                             ItemsSource="{Binding ExportedDrivers}"
                             DisplayMemberPath="FolderName"
                             AutomationProperties.Name="Eksportuotų draiverių sąrašas" />

                    <CheckBox Content="Įdėti šiuos draiverius į ISO (install.wim)" IsChecked="{Binding InjectDrivers}" Margin="0,4" />
                    <CheckBox IsChecked="{Binding AlsoInjectDriversIntoBootWim}" Margin="0,4"
                              IsEnabled="{Binding InjectDrivers}">
                        <TextBlock Text="Taip pat įdėti į boot.wim (reikalinga, jei diegimo programa nemato standžiojo disko / tinklo valdiklio)"
                                   TextWrapping="Wrap" />
                    </CheckBox>
                    <CheckBox Content="Leisti nepasirašytus draiverius (ForceUnsigned) — naudokite atsargiai"
                              IsChecked="{Binding ForceUnsignedDrivers}" Margin="0,4"
                              IsEnabled="{Binding InjectDrivers}" />
                </StackPanel>
            </TabItem>

            <!-- ============================ UNATTEND / VIETINĖ PASKYRA ============================ -->
            <TabItem Header="_Vietinė paskyra">
                <StackPanel Margin="12">
                    <CheckBox IsChecked="{Binding GenerateUnattend}" Margin="0,0,0,12">
                        <TextBlock Text="Sukurti autounattend.xml: vietinė paskyra vietoje Microsoft paskyros, praleisti privatumo/telemetrijos OOBE ekranus"
                                   TextWrapping="Wrap" />
                    </CheckBox>

                    <StackPanel IsEnabled="{Binding GenerateUnattend}">
                        <Label Content="Vietinės paskyros vardas:" Target="{Binding ElementName=AccountNameBox}" />
                        <TextBox x:Name="AccountNameBox" Text="{Binding LocalAccountName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="260" HorizontalAlignment="Left" Margin="0,0,0,8"
                                 AutomationProperties.Name="Vietinės paskyros vardas" />

                        <Label Content="Vietinės paskyros slaptažodis:" Target="{Binding ElementName=AccountPasswordBox}" />
                        <PasswordBox x:Name="AccountPasswordBox" Width="260" HorizontalAlignment="Left" Margin="0,0,0,8"
                                     PasswordChanged="AccountPasswordBox_PasswordChanged"
                                     AutomationProperties.Name="Vietinės paskyros slaptažodis" />
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" MaxWidth="500" HorizontalAlignment="Left"
                                   Text="Pastaba: slaptažodis autounattend.xml faile yra tik užkoduotas (Base64), ne tikrai apsaugotas — saugokite šį ISO/failą taip pat atsargiai, kaip ir bet kurį failą su slaptažodžiu." />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ============================ KŪRIMAS ============================ -->
            <TabItem Header="_Kūrimas">
                <StackPanel Margin="12">
                    <Label Content="Išvesties ISO failas:" Target="{Binding ElementName=OutputIsoBox}" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Naršyti..." Width="100" Margin="8,0,0,0"
                                Click="BrowseOutputIso_Click"
                                AutomationProperties.Name="Naršyti kur išsaugoti ISO failą" />
                        <TextBox x:Name="OutputIsoBox" Text="{Binding OutputIsoPath, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Išvesties ISO failo kelias" />
                    </DockPanel>

                    <Label Content="Tomo etiketė (Volume label):" Target="{Binding ElementName=VolumeLabelBox}" />
                    <TextBox x:Name="VolumeLabelBox" Text="{Binding VolumeLabel, UpdateSourceTrigger=PropertyChanged}"
                             Width="260" HorizontalAlignment="Left" Margin="0,0,0,8"
                             AutomationProperties.Name="ISO tomo etiketė" />

                    <Label Content="oscdimg.exe kelias (iš Windows ADK):" Target="{Binding ElementName=OscdimgBox}" />
                    <DockPanel Margin="0,0,0,12">
                        <Button DockPanel.Dock="Right" Content="Naršyti..." Width="100" Margin="8,0,0,0"
                                Click="BrowseOscdimg_Click"
                                AutomationProperties.Name="Naršyti oscdimg.exe failo" />
                        <TextBox x:Name="OscdimgBox" Text="{Binding OscdimgPath, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="oscdimg.exe kelias" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="K_urti optimizuotą ISO" Width="200" Height="32" Margin="0,0,8,0"
                                Command="{Binding RunCommand}"
                                AutomationProperties.Name="Pradėti optimizuoto ISO kūrimą"
                                AutomationProperties.HelpText="Pritaiko pasirinktas optimizacijas ir sukuria naują paleidžiamą ISO failą." />
                        <Button Content="_Atšaukti" Width="120" Height="32"
                                Command="{Binding CancelCommand}"
                                AutomationProperties.Name="Atšaukti vykdomą veiksmą" />
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- ============================ BŪSENA / EIGA (visada matoma) ============================ -->
        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ProgressBar Grid.Row="0" Height="18" Minimum="0" Maximum="100"
                         Value="{Binding ProgressPercent, Mode=OneWay}"
                         AutomationProperties.Name="Veiksmo eigos juosta" />

            <TextBlock x:Name="StatusLiveRegion" Grid.Row="1" Margin="0,6,0,6" FontWeight="Bold"
                       Text="{Binding StatusMessage}"
                       AutomationProperties.Name="Dabartinė būsena"
                       AutomationProperties.LiveSetting="Polite" />

            <ListBox Grid.Row="2" Height="120" ItemsSource="{Binding LogMessages}"
                     AutomationProperties.Name="Veiksmų žurnalas" />
        </Grid>
    </Grid>
</Window>
